#! /usr/bin/env ruby

case ENV['XDG_CURRENT_DESKTOP'] || ENV['XDG_SESSION_DESKTOP']
when /i3/ then x="class"
when /sway/ then x="app_id"
when /GNOME/ then x="whoops"
end

puts <<DOC
assign [#{x}="firefox-default"] 15: Playwright
assign [#{x}="firefox"] 14: Web
assign [#{x}="librewolf"] 14: Web

for_window [class='.*'] inhibit_idle fullscreen
for_window [#{x}='.*'] inhibit_idle fullscreen

assign [#{x}="slack"] 13: Slack
assign [#{x}="^FFPWA-.*"] 13: Slack
assign [#{x}="signal"] 12: Pidgin
assign [#{x}="KeePassXC"] 11: Keepass
assign [#{x}="evolution"] 100: WorkConsole

# startup apps
exec gtk-launch org.keepassxc.KeePassXC
exec librewolf
exec gtk-launch signal.desktop
exec gtk-launch org.gnome.Evolution

# Rands
exec gtk-launch FFPWA-01JT10PGTHA645AC1F4WFK8M2D.desktop
# Indy
exec gtk-launch FFPWA-01JVTRCMMJJDZFX7H6JT84VJZ3.desktop

exec cron_notify_setup

exec rem -z -k'notify-send %s &'
DOC
